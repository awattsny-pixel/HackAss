{
  "name": "hack-aggregator-backend",
  "version": "0.0.1",
  "description": "Backend API for Hack Aggregator platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@prisma/client": "5.8.0",
    "express": "4.18.2",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "jsonwebtoken": "8.5.1",
    "bcrypt": "5.1.0",
    "zod": "3.22.4",
    "winston": "3.11.0"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.10.6",
    "@types/bcrypt": "5.0.2",
    "@typescript-eslint/eslint-plugin": "6.17.0",
    "@typescript-eslint/parser": "6.17.0",
    "typescript": "5.3.3",
    "tsx": "4.7.0",
    "prisma": "5.8.0",
    "eslint": "8.56.0"
  }
}
